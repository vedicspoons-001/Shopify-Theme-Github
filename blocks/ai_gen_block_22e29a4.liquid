{% doc %}
  @prompt
    Create a "Complete The Experience" product bundle section with the heading "Complete The Experience" and subtitle "Curated additions for this box". Display 3 product cards side-by-side in a horizontal row from a product reference list metafield. Each card should have: product image at top, product title below, product description/subtitle, price in rupees, and a beige "Add to cart" button with shopping cart icon. Style with warm neutral beige/cream backgrounds, elegant serif typography for headings, clean white cards with subtle shadows and rounded corners. Add decorative horizontal lines on either side of the main heading. Make cards equal width and evenly spaced. Include section settings for metafield namespace and key, title, subtitle, and number of products to show. On mobile, stack cards vertically. Match the premium aesthetic with soft shadows and professional spacing.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bundle-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-bundle-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-bundle-heading-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 12px;
  }

  .ai-bundle-heading-line-{{ ai_gen_id }} {
    flex: 1;
    max-width: 120px;
    height: 1px;
    background-color: {{ block.settings.line_color }};
  }

  .ai-bundle-heading-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    letter-spacing: 0.5px;
  }

  .ai-bundle-subtitle-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    font-weight: 400;
  }

  .ai-bundle-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-bundle-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-bundle-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-bundle-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-bundle-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bundle-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-bundle-product-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    line-height: 1.3;
  }

  .ai-bundle-product-description-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.product_description_size }}px;
    color: {{ block.settings.product_description_color }};
    line-height: 1.5;
    flex-grow: 1;
  }

  .ai-bundle-price-{{ ai_gen_id }} {
    margin: 0 0 16px;
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-bundle-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
  }

  .ai-bundle-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-bundle-cart-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
  }

  .ai-bundle-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-bundle-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-bundle-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-bundle-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_spacing | times: 0.8 }}px;
    }

    .ai-bundle-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-bundle-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-bundle-heading-line-{{ ai_gen_id }} {
      max-width: 60px;
    }
  }
{% endstyle %}

<complete-the-experience-{{ ai_gen_id }}
  class="ai-bundle-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bundle-container-{{ ai_gen_id }}">
    <div class="ai-bundle-header-{{ ai_gen_id }}">
      <div class="ai-bundle-heading-wrapper-{{ ai_gen_id }}">
        <div class="ai-bundle-heading-line-{{ ai_gen_id }}"></div>
        <h2 class="ai-bundle-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        <div class="ai-bundle-heading-line-{{ ai_gen_id }}"></div>
      </div>
      {% if block.settings.subtitle != blank %}
        <p class="ai-bundle-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if product.metafields[block.settings.metafield_namespace][block.settings.metafield_key] != blank %}
      {% assign bundle_products = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key].value %}
      
      {% if bundle_products.size > 0 %}
        <div class="ai-bundle-grid-{{ ai_gen_id }}">
          {% for bundle_product in bundle_products limit: block.settings.products_to_show %}
            <div class="ai-bundle-card-{{ ai_gen_id }}">
              <div class="ai-bundle-image-wrapper-{{ ai_gen_id }}">
                {% if bundle_product.featured_image %}
                  <img
                    src="{{ bundle_product.featured_image | image_url: width: 600 }}"
                    alt="{{ bundle_product.featured_image.alt | escape }}"
                    class="ai-bundle-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-bundle-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-bundle-card-content-{{ ai_gen_id }}">
                <h3 class="ai-bundle-product-title-{{ ai_gen_id }}">{{ bundle_product.title }}</h3>
                
                {% if bundle_product.metafields.custom.subtitle != blank %}
                  <p class="ai-bundle-product-description-{{ ai_gen_id }}">
                    {{ bundle_product.metafields.custom.subtitle }}
                  </p>
                {% elsif bundle_product.description != blank %}
                  <p class="ai-bundle-product-description-{{ ai_gen_id }}">
                    {{ bundle_product.description | strip_html | truncate: 80 }}
                  </p>
                {% endif %}

                <div class="ai-bundle-price-{{ ai_gen_id }}">
                  ₹{{ bundle_product.price | money_without_currency }}
                </div>

                <a
                  href="{{ bundle_product.url }}"
                  class="ai-bundle-add-to-cart-{{ ai_gen_id }}"
                >
                  <svg
                    class="ai-bundle-cart-icon-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                  </svg>
                  {{ block.settings.button_text }}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="ai-bundle-empty-state-{{ ai_gen_id }}">
          No products found in the metafield. Please add products to the "{{ block.settings.metafield_namespace }}.{{ block.settings.metafield_key }}" metafield.
        </div>
      {% endif %}
    {% else %}
      <div class="ai-bundle-empty-state-{{ ai_gen_id }}">
        Configure the metafield namespace and key in the block settings to display products.
      </div>
    {% endif %}
  </div>
</complete-the-experience-{{ ai_gen_id }}>

<script>
  (function() {
    class CompleteTheExperience{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAddToCart();
      }

      setupAddToCart() {
        const buttons = this.querySelectorAll('.ai-bundle-add-to-cart-{{ ai_gen_id }}');
        
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            const productUrl = button.getAttribute('href');
            if (productUrl) {
              window.location.href = productUrl;
            }
          });
        });
      }
    }

    customElements.define('complete-the-experience-{{ ai_gen_id }}', CompleteTheExperience{{ ai_gen_id }});
  })();
</script>

