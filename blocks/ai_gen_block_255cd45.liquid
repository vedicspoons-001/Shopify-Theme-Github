{% doc %}
  @prompt Delivery Address Selector - Address only, no checkout button
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-delivery-selector-{{ ai_gen_id }} {
    display: block; width: 100%;
    font-family: var(--font-body-family, 'Inter', sans-serif);
  }
  .ai-delivery-selector__heading-wrap-{{ ai_gen_id }} {
    display: flex; align-items: center; gap: 9px; margin-bottom: 3px;
  }
  .ai-delivery-selector__heading-icon-{{ ai_gen_id }} {
    width: 26px; height: 26px;
    background: linear-gradient(135deg, {{ block.settings.accent_color }}, #b8960a);
    border-radius: 7px; display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(212,175,55,0.3);
  }
  .ai-delivery-selector__heading-{{ ai_gen_id }} {
    font-size: 15px; color: {{ block.settings.text_color }}; margin: 0;
    font-weight: 700; font-family: var(--font-heading-family, serif);
    letter-spacing: 0.02em;
  }
  @media (max-width: 749px) { .ai-delivery-selector__heading-{{ ai_gen_id }} { font-size: 14px; } }
  .ai-delivery-selector__subheading-{{ ai_gen_id }} {
    font-size: 10.5px; color: {{ block.settings.text_color }};
    opacity: 0.35; margin: 0 0 11px 35px;
    letter-spacing: 0.03em; font-style: italic;
  }
  .ai-delivery-selector__compact-box-{{ ai_gen_id }} {
    background: {{ block.settings.card_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 16px; padding: 14px;
    box-shadow: 0 1px 3px rgba(61,35,20,0.04),
                0 4px 20px rgba(61,35,20,0.07),
                inset 0 1px 0 rgba(255,255,255,0.8);
  }
  .ai-delivery-selector__btn-{{ ai_gen_id }} {
    width: 100%; padding: 12px 18px; border-radius: 11px;
    font-size: 13.5px; font-weight: 600; cursor: pointer;
    transition: all 0.25s ease; border: none; text-align: center;
    text-decoration: none; display: flex; align-items: center;
    justify-content: center; gap: 8px; letter-spacing: 0.02em;
    box-sizing: border-box; font-family: inherit;
  }
  @media (max-width: 749px) { .ai-delivery-selector__btn-{{ ai_gen_id }} { font-size: 13px; padding: 11px 16px; } }
  .ai-delivery-selector__btn-primary-{{ ai_gen_id }} {
    background: {{ block.settings.text_color }}; color: #fff;
    box-shadow: 0 2px 10px rgba(61,35,20,0.2);
  }
  .ai-delivery-selector__btn-primary-{{ ai_gen_id }}:hover {
    opacity: 0.87; transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(61,35,20,0.25);
  }
  .ai-delivery-selector__selected-address-{{ ai_gen_id }} {
    margin-top: 12px; padding: 13px 14px;
    background: linear-gradient(135deg, #fffef9 0%, #fdf8e8 100%);
    border: 1.5px solid {{ block.settings.accent_color }};
    border-radius: 12px; position: relative;
    box-shadow: 0 2px 12px rgba(212,175,55,0.12), inset 0 1px 0 rgba(255,255,255,0.9);
  }
  .ai-delivery-selector__selected-label-{{ ai_gen_id }} {
    font-size: 9.5px; color: {{ block.settings.accent_color }};
    font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; margin-bottom: 5px;
  }
  .ai-delivery-selector__selected-name-{{ ai_gen_id }} {
    font-size: 13px; font-weight: 700;
    color: {{ block.settings.text_color }}; margin-bottom: 3px;
    font-family: var(--font-heading-family, serif);
  }
  .ai-delivery-selector__selected-details-{{ ai_gen_id }} {
    font-size: 11.5px; color: {{ block.settings.text_color }};
    opacity: 0.55; line-height: 1.6;
  }
  .ai-delivery-selector__change-btn-{{ ai_gen_id }} {
    position: absolute; top: 11px; right: 11px;
    padding: 4px 11px; background: transparent;
    color: {{ block.settings.accent_color }};
    border: 1px solid {{ block.settings.accent_color }};
    border-radius: 20px; font-size: 10.5px; font-weight: 600;
    cursor: pointer; transition: all 0.22s ease;
    letter-spacing: 0.02em; font-family: inherit;
  }
  .ai-delivery-selector__change-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.accent_color }}; color: #fff;
  }
  .ai-delivery-selector__modal-overlay-{{ ai_gen_id }} {
    position: fixed; inset: 0; background: rgba(45,26,14,0.45);
    backdrop-filter: blur(4px); z-index: 9998;
    opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .ai-delivery-selector__modal-overlay-{{ ai_gen_id }}.active { opacity: 1; visibility: visible; }
  .ai-delivery-selector__modal-{{ ai_gen_id }} {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -48%) scale(0.94);
    background: #faf8f4; border-radius: 18px;
    box-shadow: 0 24px 64px rgba(45,26,14,0.2),
                0 4px 16px rgba(45,26,14,0.1),
                inset 0 1px 0 rgba(255,255,255,0.9);
    z-index: 9999; width: 92%; max-width: 480px;
    max-height: 90vh; overflow-y: auto;
    opacity: 0; visibility: hidden;
    transition: all 0.3s cubic-bezier(0.34,1.4,0.64,1);
  }
  .ai-delivery-selector__modal-{{ ai_gen_id }}.active {
    opacity: 1; visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }
  .ai-delivery-selector__modal-{{ ai_gen_id }}::-webkit-scrollbar { width: 3px; }
  .ai-delivery-selector__modal-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: {{ block.settings.accent_color }}; border-radius: 3px;
  }
  .ai-delivery-selector__modal-header-{{ ai_gen_id }} {
    padding: 16px 18px 14px; border-bottom: 1px solid #e8dcc8;
    display: flex; justify-content: space-between; align-items: center;
    position: sticky; top: 0; background: #faf8f4; z-index: 1;
    border-radius: 18px 18px 0 0;
  }
  .ai-delivery-selector__modal-header-left-{{ ai_gen_id }} {
    display: flex; align-items: center; gap: 10px;
  }
  .ai-delivery-selector__modal-icon-{{ ai_gen_id }} {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, {{ block.settings.accent_color }}, #b8960a);
    border-radius: 9px; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(212,175,55,0.28);
  }
  .ai-delivery-selector__modal-title-{{ ai_gen_id }} {
    font-size: 15px; font-weight: 700; color: {{ block.settings.text_color }}; margin: 0;
    font-family: var(--font-heading-family, serif); letter-spacing: 0.02em;
  }
  .ai-delivery-selector__modal-close-{{ ai_gen_id }} {
    width: 30px; height: 30px; background: #ede8df; border: none; border-radius: 50%;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: {{ block.settings.text_color }}; opacity: 0.5; transition: all 0.22s ease; flex-shrink: 0;
  }
  .ai-delivery-selector__modal-close-{{ ai_gen_id }}:hover {
    opacity: 1; background: #e0d8cc; transform: rotate(90deg);
  }
  .ai-delivery-selector__modal-body-{{ ai_gen_id }} { padding: 16px 18px; }
  .ai-delivery-selector__search-wrap-{{ ai_gen_id }} { position: relative; margin-bottom: 11px; }
  .ai-delivery-selector__search-icon-{{ ai_gen_id }} {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: {{ block.settings.text_color }}; opacity: 0.28; pointer-events: none;
  }
  .ai-delivery-selector__search-{{ ai_gen_id }} {
    width: 100%; padding: 8px 11px 8px 32px; border: 1.5px solid #e8dcc8;
    border-radius: 9px; font-size: 12.5px; color: {{ block.settings.text_color }};
    background: #fff; box-sizing: border-box; outline: none;
    transition: border-color 0.22s, box-shadow 0.22s; font-family: inherit;
  }
  .ai-delivery-selector__search-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 3px rgba(212,175,55,0.1);
  }
  .ai-delivery-selector__saved-title-{{ ai_gen_id }} {
    font-size: 9.5px; font-weight: 700; color: {{ block.settings.text_color }};
    opacity: 0.35; text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 9px;
    display: flex; align-items: center; gap: 6px;
  }
  .ai-delivery-selector__saved-title-{{ ai_gen_id }}::before {
    content: ''; display: inline-block; width: 16px; height: 1px;
    background: {{ block.settings.accent_color }}; opacity: 0.5;
  }
  .ai-delivery-selector__list-wrap-{{ ai_gen_id }} {
    max-height: 230px; overflow-y: auto; border-radius: 10px;
  }
  .ai-delivery-selector__list-wrap-{{ ai_gen_id }}::-webkit-scrollbar { width: 3px; }
  .ai-delivery-selector__list-wrap-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: {{ block.settings.accent_color }}; border-radius: 3px;
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }} {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 11px 12px; border: 1.5px solid #e8dcc8;
    border-radius: 11px; margin-bottom: 7px; cursor: pointer;
    transition: all 0.22s cubic-bezier(0.34,1.2,0.64,1);
    background: #fff; position: relative; overflow: hidden;
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, {{ block.settings.accent_color }}, #b8960a);
    transform: scaleY(0); transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); border-radius: 0 2px 2px 0;
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}.selected::before { transform: scaleY(1); }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 3px 12px rgba(212,175,55,0.1); transform: translateY(-1px);
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.accent_color }};
    background: linear-gradient(135deg, #fffef9, #fdf8e8);
    box-shadow: 0 3px 14px rgba(212,175,55,0.14); transform: translateY(0);
  }
  .ai-delivery-selector__card-radio-{{ ai_gen_id }} {
    width: 16px; height: 16px; min-width: 16px; border-radius: 50%;
    border: 2px solid #d8cfc4; display: flex; align-items: center;
    justify-content: center; margin-top: 2px;
    transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1); background: #fff; flex-shrink: 0;
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}.selected .ai-delivery-selector__card-radio-{{ ai_gen_id }} {
    background: {{ block.settings.accent_color }}; border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 3px rgba(212,175,55,0.18); transform: scale(1.1);
  }
  .ai-delivery-selector__card-radio-dot-{{ ai_gen_id }} {
    width: 5px; height: 5px; border-radius: 50%; background: #fff; opacity: 0;
    transition: opacity 0.2s, transform 0.25s cubic-bezier(0.34,1.56,0.64,1); transform: scale(0);
  }
  .ai-delivery-selector__address-card-{{ ai_gen_id }}.selected .ai-delivery-selector__card-radio-dot-{{ ai_gen_id }} {
    opacity: 1; transform: scale(1);
  }
  .ai-delivery-selector__address-name-{{ ai_gen_id }} {
    font-size: 12.5px; font-weight: 700; color: {{ block.settings.text_color }}; margin-bottom: 3px;
    font-family: var(--font-heading-family, serif);
  }
  .ai-delivery-selector__address-text-{{ ai_gen_id }} {
    font-size: 11.5px; color: {{ block.settings.text_color }}; opacity: 0.52; line-height: 1.55;
  }
  .ai-delivery-selector__address-badge-{{ ai_gen_id }} {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 9.5px; font-weight: 600; color: {{ block.settings.accent_color }};
    background: rgba(212,175,55,0.1); padding: 2px 8px;
    border-radius: 20px; margin-top: 5px; box-shadow: 0 0 0 1px rgba(212,175,55,0.2);
  }
  .ai-delivery-selector__no-results-{{ ai_gen_id }} {
    text-align: center; padding: 18px; font-size: 12px;
    color: {{ block.settings.text_color }}; opacity: 0.3; display: none;
  }
  .ai-delivery-selector__divider-{{ ai_gen_id }} {
    display: flex; align-items: center; gap: 10px; margin: 14px 0;
  }
  .ai-delivery-selector__divider-line-{{ ai_gen_id }} { flex: 1; height: 1px; background: #e8dcc8; }
  .ai-delivery-selector__divider-text-{{ ai_gen_id }} {
    font-size: 9.5px; color: {{ block.settings.text_color }};
    opacity: 0.3; font-weight: 700; letter-spacing: 0.08em;
  }
  .ai-delivery-selector__add-new-btn-{{ ai_gen_id }} {
    display: flex; align-items: center; justify-content: center; gap: 7px;
    width: 100%; padding: 9px 13px; background: transparent;
    border: 1.5px dashed {{ block.settings.accent_color }};
    border-radius: 10px; color: {{ block.settings.accent_color }};
    font-size: 12.5px; font-weight: 600; cursor: pointer;
    transition: all 0.22s ease; box-sizing: border-box; font-family: inherit; letter-spacing: 0.02em;
  }
  .ai-delivery-selector__add-new-btn-{{ ai_gen_id }}:hover {
    background: rgba(212,175,55,0.07); border-style: solid; transform: translateY(-1px);
  }
  .ai-delivery-selector__new-form-wrap-{{ ai_gen_id }} { margin-top: 13px; }
  .ai-delivery-selector__new-address-title-{{ ai_gen_id }} {
    font-size: 9.5px; font-weight: 700; color: {{ block.settings.text_color }};
    opacity: 0.32; text-transform: uppercase; letter-spacing: 0.09em;
    margin-bottom: 12px; display: flex; align-items: center; gap: 6px;
  }
  .ai-delivery-selector__new-address-title-{{ ai_gen_id }}::before {
    content: ''; display: inline-block; width: 16px; height: 1px;
    background: {{ block.settings.accent_color }}; opacity: 0.5;
  }
  .ai-delivery-selector__form-field-{{ ai_gen_id }} { margin-bottom: 9px; }
  .ai-delivery-selector__form-label-{{ ai_gen_id }} {
    display: block; font-size: 9.5px; color: {{ block.settings.text_color }};
    font-weight: 700; margin-bottom: 4px; opacity: 0.38;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .ai-delivery-selector__form-input-{{ ai_gen_id }},
  .ai-delivery-selector__form-select-{{ ai_gen_id }} {
    width: 100%; padding: 9px 11px; border: 1.5px solid #e8dcc8;
    border-radius: 8px; font-size: 13px; background: #fff;
    color: {{ block.settings.text_color }};
    transition: border-color 0.22s, box-shadow 0.22s;
    box-sizing: border-box; outline: none; font-family: inherit;
  }
  .ai-delivery-selector__form-input-{{ ai_gen_id }}:focus,
  .ai-delivery-selector__form-select-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 3px rgba(212,175,55,0.1);
  }
  .ai-delivery-selector__form-row-{{ ai_gen_id }} {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  }
  @media (max-width: 749px) {
    .ai-delivery-selector__form-row-{{ ai_gen_id }} { grid-template-columns: 1fr; }
  }
  .ai-delivery-selector__modal-footer-{{ ai_gen_id }} {
    padding: 13px 18px; border-top: 1px solid #e8dcc8;
    display: flex; gap: 8px; justify-content: flex-end;
    position: sticky; bottom: 0; background: #faf8f4; border-radius: 0 0 18px 18px;
  }
  .ai-delivery-selector__footer-cancel-{{ ai_gen_id }} {
    padding: 9px 17px; background: transparent; color: {{ block.settings.text_color }};
    border: 1.5px solid #e8dcc8; border-radius: 9px;
    font-size: 12px; font-weight: 500; cursor: pointer; transition: all 0.22s; font-family: inherit;
  }
  .ai-delivery-selector__footer-cancel-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }}; color: {{ block.settings.accent_color }};
  }
  .ai-delivery-selector__footer-save-{{ ai_gen_id }} {
    padding: 9px 20px; background: {{ block.settings.text_color }};
    color: #fff; border: none; border-radius: 9px;
    font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.22s;
    display: flex; align-items: center; gap: 6px; font-family: inherit;
    letter-spacing: 0.02em; box-shadow: 0 2px 8px rgba(61,35,20,0.2);
  }
  .ai-delivery-selector__footer-save-{{ ai_gen_id }}:hover { opacity: 0.87; transform: translateY(-1px); }
  .ai-delivery-selector__footer-save-{{ ai_gen_id }}:disabled {
    background: #ccc; cursor: not-allowed; transform: none; box-shadow: none;
  }
  .ai-delivery-selector__hidden-{{ ai_gen_id }} { display: none !important; }
{% endstyle %}

{% if customer %}
  {% form 'customer_address', customer.new_address %}
    <input type="hidden" id="das-csrf-{{ ai_gen_id }}" value="{{ form.authenticity_token }}">
  {% endform %}
{% endif %}

<delivery-address-selector-{{ ai_gen_id }}
  class="ai-delivery-selector-{{ ai_gen_id }}"
  id="vs-addr-selector-block"
  {{ block.shopify_attributes }}
>
  <div>
    {% if block.settings.heading != blank %}
      <div class="ai-delivery-selector__heading-wrap-{{ ai_gen_id }}">
        <div class="ai-delivery-selector__heading-icon-{{ ai_gen_id }}">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <h2 class="ai-delivery-selector__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
      <p class="ai-delivery-selector__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}

    <div class="ai-delivery-selector__compact-box-{{ ai_gen_id }}">
      {% if customer %}
        <button class="ai-delivery-selector__btn-{{ ai_gen_id }} ai-delivery-selector__btn-primary-{{ ai_gen_id }}" data-view-saved-btn>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          My Addresses
        </button>
      {% else %}
        <a href="/account/login?return_url={{ request.path | url_encode }}"
           class="ai-delivery-selector__btn-{{ ai_gen_id }} ai-delivery-selector__btn-primary-{{ ai_gen_id }}">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          Login to See Saved Addresses
        </a>
      {% endif %}

      <div class="ai-delivery-selector__selected-address-{{ ai_gen_id }} ai-delivery-selector__hidden-{{ ai_gen_id }}" data-selected-display>
        <button class="ai-delivery-selector__change-btn-{{ ai_gen_id }}" data-change-btn>✏️ Change</button>
        <div class="ai-delivery-selector__selected-label-{{ ai_gen_id }}">✅ Delivering To</div>
        <div class="ai-delivery-selector__selected-name-{{ ai_gen_id }}" data-display-name></div>
        <div class="ai-delivery-selector__selected-details-{{ ai_gen_id }}" data-display-details></div>
      </div>
    </div>
  </div>

  <div class="ai-delivery-selector__modal-overlay-{{ ai_gen_id }}" data-modal-overlay></div>

  <div class="ai-delivery-selector__modal-{{ ai_gen_id }}" data-modal>
    <div class="ai-delivery-selector__modal-header-{{ ai_gen_id }}">
      <div class="ai-delivery-selector__modal-header-left-{{ ai_gen_id }}">
        <div class="ai-delivery-selector__modal-icon-{{ ai_gen_id }}">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <h3 class="ai-delivery-selector__modal-title-{{ ai_gen_id }}">My Addresses</h3>
      </div>
      <button class="ai-delivery-selector__modal-close-{{ ai_gen_id }}" data-modal-close>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="ai-delivery-selector__modal-body-{{ ai_gen_id }}">
      {% if customer and customer.addresses.size > 0 %}
        <div data-saved-section>
          <div class="ai-delivery-selector__saved-title-{{ ai_gen_id }}">Saved Addresses</div>
          <div class="ai-delivery-selector__search-wrap-{{ ai_gen_id }}">
            <svg class="ai-delivery-selector__search-icon-{{ ai_gen_id }}" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" class="ai-delivery-selector__search-{{ ai_gen_id }}" data-search-input placeholder="Search addresses..." autocomplete="off">
          </div>
          <div class="ai-delivery-selector__list-wrap-{{ ai_gen_id }}">
            {% for address in customer.addresses %}
              <div class="ai-delivery-selector__address-card-{{ ai_gen_id }}"
                data-saved-card
                data-idx="{{ forloop.index0 }}"
                data-first-name="{{ address.first_name | escape }}"
                data-last-name="{{ address.last_name | escape }}"
                data-address1="{{ address.address1 | escape }}"
                data-address2="{{ address.address2 | escape }}"
                data-city="{{ address.city | escape }}"
                data-province="{{ address.province | escape }}"
                data-zip="{{ address.zip | escape }}"
                data-country="{{ address.country | escape }}"
                data-phone="{{ address.phone | escape }}"
                data-search-text="{{ address.first_name }} {{ address.last_name }} {{ address.address1 }} {{ address.city }} {{ address.zip }}"
                data-is-default="{% if address == customer.default_address %}true{% else %}false{% endif %}"
              >
                <div class="ai-delivery-selector__card-radio-{{ ai_gen_id }}">
                  <div class="ai-delivery-selector__card-radio-dot-{{ ai_gen_id }}"></div>
                </div>
                <div style="flex:1;min-width:0">
                  <div class="ai-delivery-selector__address-name-{{ ai_gen_id }}">
                    {{ address.first_name }} {{ address.last_name }}
                  </div>
                  <div class="ai-delivery-selector__address-text-{{ ai_gen_id }}">
                    {{ address.address1 }}{% if address.address2 != blank %}, {{ address.address2 }}{% endif %}<br>
                    {{ address.city }}{% if address.province != blank %}, {{ address.province }}{% endif %} {{ address.zip }}<br>
                    {{ address.country }}
                    {% if block.settings.show_phone and address.phone != blank %}<br>📞 {{ address.phone }}{% endif %}
                  </div>
                  {% if address == customer.default_address %}
                    <div class="ai-delivery-selector__address-badge-{{ ai_gen_id }}">⭐ Default</div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
            <div class="ai-delivery-selector__no-results-{{ ai_gen_id }}" data-no-results>🔍 No addresses match.</div>
          </div>
          <div class="ai-delivery-selector__divider-{{ ai_gen_id }}">
            <div class="ai-delivery-selector__divider-line-{{ ai_gen_id }}"></div>
            <span class="ai-delivery-selector__divider-text-{{ ai_gen_id }}">OR ADD NEW</span>
            <div class="ai-delivery-selector__divider-line-{{ ai_gen_id }}"></div>
          </div>
          <button class="ai-delivery-selector__add-new-btn-{{ ai_gen_id }}" data-toggle-form-btn>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Add New Address
          </button>
        </div>
      {% endif %}

      <div class="ai-delivery-selector__new-form-wrap-{{ ai_gen_id }}" data-new-form-wrap
        {% if customer and customer.addresses.size > 0 %}style="display:none"{% endif %}
      >
        <div class="ai-delivery-selector__new-address-title-{{ ai_gen_id }}">
          {% if customer and customer.addresses.size > 0 %}New Address{% else %}Add Your Address{% endif %}
        </div>
        <form data-address-form>
          <div class="ai-delivery-selector__form-row-{{ ai_gen_id }}">
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">First Name *</label>
              <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="first_name" placeholder="First name" required>
            </div>
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">Last Name *</label>
              <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="last_name" placeholder="Last name" required>
            </div>
          </div>
          <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
            <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">Address Line 1 *</label>
            <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="address1" placeholder="Street, building, area" required>
          </div>
          <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
            <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">Address Line 2</label>
            <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="address2" placeholder="Apartment, floor, landmark (optional)">
          </div>
          <div class="ai-delivery-selector__form-row-{{ ai_gen_id }}">
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">City *</label>
              <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="city" placeholder="City" required>
            </div>
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">State *</label>
              <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="province" placeholder="State" required>
            </div>
          </div>
          <div class="ai-delivery-selector__form-row-{{ ai_gen_id }}">
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">PIN Code *</label>
              <input type="text" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="zip" placeholder="6-digit PIN" required inputmode="numeric" maxlength="6">
            </div>
            <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
              <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">Country *</label>
              <select class="ai-delivery-selector__form-select-{{ ai_gen_id }}" data-field="country" required>
                <option value="">Select</option>
                <option value="India" selected>India</option>
                <option value="United States">United States</option>
                <option value="United Kingdom">United Kingdom</option>
                <option value="Canada">Canada</option>
                <option value="Australia">Australia</option>
                <option value="Singapore">Singapore</option>
                <option value="UAE">UAE</option>
              </select>
            </div>
          </div>
          <div class="ai-delivery-selector__form-field-{{ ai_gen_id }}">
            <label class="ai-delivery-selector__form-label-{{ ai_gen_id }}">Phone</label>
            <input type="tel" class="ai-delivery-selector__form-input-{{ ai_gen_id }}" data-field="phone" placeholder="+91 XXXXX XXXXX">
          </div>
        </form>
      </div>
    </div>

    <div class="ai-delivery-selector__modal-footer-{{ ai_gen_id }}">
      <button class="ai-delivery-selector__footer-cancel-{{ ai_gen_id }}" data-modal-cancel>Cancel</button>
      <button class="ai-delivery-selector__footer-save-{{ ai_gen_id }}" data-modal-save>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Save & Use Address
      </button>
    </div>
  </div>
</delivery-address-selector-{{ ai_gen_id }}>

<script>
(function() {
  const SS = {
    zip       : 'vs_selected_zip',
    city      : 'vs_selected_city',
    idx       : 'vs_selected_addr_idx',
    name      : 'vs_selected_addr_name',
    dtls      : 'vs_selected_addr_dtls',
    firstName : 'vs_addr_first_name',
    lastName  : 'vs_addr_last_name',
    address1  : 'vs_addr_address1',
    address2  : 'vs_addr_address2',
    province  : 'vs_addr_province',
    country   : 'vs_addr_country',
    phone     : 'vs_addr_phone'
  };

  class DeliveryAddressSelector{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.selectedAddress = null;
      this.isCustomer      = {{ customer | json }} !== null;
      this.formVisible     = false;
      this._lastCartSig    = null;
    }

    connectedCallback() {
      this.viewSavedBtn    = this.querySelector('[data-view-saved-btn]');
      this.changeBtn       = this.querySelector('[data-change-btn]');
      this.modalOverlay    = this.querySelector('[data-modal-overlay]');
      this.modal           = this.querySelector('[data-modal]');
      this.modalClose      = this.querySelector('[data-modal-close]');
      this.modalCancel     = this.querySelector('[data-modal-cancel]');
      this.modalSave       = this.querySelector('[data-modal-save]');
      this.addressForm     = this.querySelector('[data-address-form]');
      this.savedSection    = this.querySelector('[data-saved-section]');
      this.savedCards      = Array.from(this.querySelectorAll('[data-saved-card]'));
      this.selectedDisplay = this.querySelector('[data-selected-display]');
      this.displayName     = this.querySelector('[data-display-name]');
      this.displayDetails  = this.querySelector('[data-display-details]');
      this.searchInput     = this.querySelector('[data-search-input]');
      this.noResults       = this.querySelector('[data-no-results]');
      this.toggleFormBtn   = this.querySelector('[data-toggle-form-btn]');
      this.newFormWrap     = this.querySelector('[data-new-form-wrap]');
      this.csrfToken       = document.getElementById('das-csrf-{{ ai_gen_id }}')?.value || '';

      this._setupEvents();
      this._restoreSelection();
      this._startCartPoll();
    }

    _restoreSelection() {
      const savedIdx  = sessionStorage.getItem(SS.idx);
      const savedName = sessionStorage.getItem(SS.name);
      const savedDtls = sessionStorage.getItem(SS.dtls);

      if (savedIdx !== null && savedName) {
        const card = this.savedCards.find(c => c.dataset.idx === savedIdx);
        if (card) {
          this._highlightCard(card);
          this.selectedAddress = this._cardToAddr(card);
        }
        if (this.displayName)    this.displayName.textContent  = savedName;
        if (this.displayDetails) this.displayDetails.innerHTML = savedDtls || '';
        if (this.selectedDisplay) this.selectedDisplay.classList.remove('ai-delivery-selector__hidden-{{ ai_gen_id }}');
        return;
      }

      // Nothing saved yet — auto-select default address
      if (this.savedCards.length > 0) {
        const def = this.savedCards.find(c => c.dataset.isDefault === 'true') || this.savedCards[0];
        this._commitSelection(def);
      }
    }

    // ── Cart poll: ONLY re-broadcast zip, NEVER clear address ──
    _startCartPoll() {
      setInterval(() => {
        fetch('/cart.js').then(r => r.json()).then(cart => {
          const sig = cart.total_price + '_' + cart.total_weight + '_' + cart.item_count;
          if (this._lastCartSig !== null && this._lastCartSig !== sig) {
            // Re-broadcast zip to trigger delivery block price recalc
            const zip = sessionStorage.getItem(SS.zip) || '';
            if (zip) {
              sessionStorage.setItem(SS.zip, '');
              setTimeout(() => sessionStorage.setItem(SS.zip, zip), 80);
            }
            // Re-render display box in case cart JS re-rendered the DOM
            const name = sessionStorage.getItem(SS.name) || '';
            const dtls = sessionStorage.getItem(SS.dtls) || '';
            const idx  = sessionStorage.getItem(SS.idx);
            if (name && this.displayName) {
              this.displayName.textContent  = name;
              this.displayDetails.innerHTML = dtls;
              this.selectedDisplay.classList.remove('ai-delivery-selector__hidden-{{ ai_gen_id }}');
              if (idx !== null) {
                const card = this.savedCards.find(c => c.dataset.idx === idx);
                if (card) this._highlightCard(card);
              }
            }
          }
          this._lastCartSig = sig;
        }).catch(() => {});
      }, 1500);
    }

    _cardToAddr(card) {
      return {
        first_name : card.dataset.firstName || '',
        last_name  : card.dataset.lastName  || '',
        address1   : card.dataset.address1  || '',
        address2   : card.dataset.address2  || '',
        city       : card.dataset.city      || '',
        province   : card.dataset.province  || '',
        zip        : card.dataset.zip       || '',
        country    : card.dataset.country   || '',
        phone      : card.dataset.phone     || ''
      };
    }

    _highlightCard(card) {
      this.savedCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    }

    _saveToSession(addr, idx) {
      sessionStorage.setItem(SS.zip,       addr.zip        || '');
      sessionStorage.setItem(SS.city,      addr.city       || '');
      sessionStorage.setItem(SS.firstName, addr.first_name || '');
      sessionStorage.setItem(SS.lastName,  addr.last_name  || '');
      sessionStorage.setItem(SS.address1,  addr.address1   || '');
      sessionStorage.setItem(SS.address2,  addr.address2   || '');
      sessionStorage.setItem(SS.province,  addr.province   || '');
      sessionStorage.setItem(SS.country,   addr.country    || 'India');
      sessionStorage.setItem(SS.phone,     addr.phone      || '');

      const name = (addr.first_name + ' ' + addr.last_name).trim();
      let dtls = addr.address1;
      if (addr.address2) dtls += ', ' + addr.address2;
      dtls += '<br>' + addr.city;
      if (addr.province) dtls += ', ' + addr.province;
      dtls += ' ' + addr.zip + '<br>' + addr.country;
      if (addr.phone) dtls += '<br>📞 ' + addr.phone;

      sessionStorage.setItem(SS.name, name);
      sessionStorage.setItem(SS.dtls, dtls);
      if (idx !== undefined) sessionStorage.setItem(SS.idx, String(idx));
      else sessionStorage.removeItem(SS.idx);

      return { name, dtls };
    }

    _commitSelection(card) {
      this._highlightCard(card);
      this.selectedAddress = this._cardToAddr(card);
      const { name, dtls } = this._saveToSession(this.selectedAddress, card.dataset.idx);

      fetch('/cart/update.js', {
        method  : 'POST',
        headers : { 'Content-Type': 'application/json' },
        body    : JSON.stringify({ attributes: {
          'Delivery Pincode' : this.selectedAddress.zip,
          'Delivery City'    : this.selectedAddress.city,
          'Delivery Name'    : name
        }})
      }).catch(() => {});

      if (this.displayName)    this.displayName.textContent  = name;
      if (this.displayDetails) this.displayDetails.innerHTML = dtls;
      if (this.selectedDisplay) this.selectedDisplay.classList.remove('ai-delivery-selector__hidden-{{ ai_gen_id }}');
    }

    _setupEvents() {
      if (this.viewSavedBtn) this.viewSavedBtn.addEventListener('click', () => this.openModal());
      if (this.changeBtn)    this.changeBtn.addEventListener('click',    () => this.openModal());
      this.modalOverlay.addEventListener('click', () => this.closeModal());
      this.modalClose.addEventListener('click',   () => this.closeModal());
      this.modalCancel.addEventListener('click',  () => this.closeModal());
      this.modalSave.addEventListener('click',    () => this._saveAddress());

      this.savedCards.forEach(card => {
        card.addEventListener('click', () => {
          this._commitSelection(card);
          this.closeModal();
        });
      });

      if (this.toggleFormBtn && this.newFormWrap) {
        this.toggleFormBtn.addEventListener('click', () => {
          this.formVisible = !this.formVisible;
          this.newFormWrap.style.display = this.formVisible ? 'block' : 'none';
          this.toggleFormBtn.innerHTML = this.formVisible
            ? `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> Cancel`
            : `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg> Add New Address`;
        });
      }

      if (this.searchInput) {
        this.searchInput.addEventListener('input', () => {
          const q = this.searchInput.value.toLowerCase();
          let count = 0;
          this.savedCards.forEach(card => {
            const match = card.dataset.searchText.toLowerCase().includes(q);
            card.style.display = match ? '' : 'none';
            if (match) count++;
          });
          if (this.noResults) this.noResults.style.display = count === 0 ? 'block' : 'none';
        });
      }

      document.addEventListener('keydown', e => { if (e.key === 'Escape') this.closeModal(); });
    }

    openModal() {
      this.modalOverlay.classList.add('active');
      this.modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      this.formVisible = false;
      if (this.newFormWrap && this.savedSection) this.newFormWrap.style.display = 'none';
      if (this.toggleFormBtn) {
        this.toggleFormBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg> Add New Address`;
      }
    }

    closeModal() {
      this.modalOverlay.classList.remove('active');
      this.modal.classList.remove('active');
      document.body.style.overflow = '';
      this._clearForm();
      if (this.searchInput) this.searchInput.value = '';
      this.savedCards.forEach(card => { card.style.display = ''; });
      if (this.noResults) this.noResults.style.display = 'none';
    }

    _getFormData() {
      const data = {};
      this.addressForm.querySelectorAll('[data-field]').forEach(input => {
        data[input.dataset.field] = input.value.trim();
      });
      return data;
    }

    _validateForm() {
      const d = this._getFormData();
      return d.first_name && d.last_name && d.address1 && d.city && d.province && d.zip && d.country;
    }

    _saveAddress() {
      if (this.newFormWrap && this.newFormWrap.style.display === 'none') { this.closeModal(); return; }
      if (!this._validateForm()) { alert('Please fill in all required fields (*)'); return; }

      const formData = this._getFormData();
      this.selectedAddress = formData;
      const { name, dtls } = this._saveToSession(formData);

      if (this.displayName)    this.displayName.textContent  = name;
      if (this.displayDetails) this.displayDetails.innerHTML = dtls;
      if (this.selectedDisplay) this.selectedDisplay.classList.remove('ai-delivery-selector__hidden-{{ ai_gen_id }}');

      if (this.isCustomer) {
        this.modalSave.disabled = true;
        this.modalSave.innerHTML = 'Saving...';
        const fd = new FormData();
        fd.append('form_type', 'customer_address');
        fd.append('utf8', '✓');
        fd.append('authenticity_token', this.csrfToken);
        Object.keys(formData).forEach(key => fd.append(`address[${key}]`, formData[key]));
        fetch('/account/addresses', {
          method: 'POST', body: fd, credentials: 'same-origin',
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).finally(() => {
          this.closeModal();
          this.modalSave.disabled = false;
          this.modalSave.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg> Save & Use Address`;
        });
      } else {
        this.closeModal();
      }
    }

    _clearForm() {
      if (!this.addressForm) return;
      this.addressForm.querySelectorAll('[data-field]').forEach(input => {
        if (input.tagName === 'SELECT') input.selectedIndex = 0;
        else input.value = '';
      });
    }
  }

  customElements.define(
    'delivery-address-selector-{{ ai_gen_id }}',
    DeliveryAddressSelector{{ ai_gen_id }}
  );
})();
</script>

{% schema %}
{
  "name": "Delivery Address Selector",
  "settings": [
    { "type": "text",     "id": "heading",      "label": "Heading",         "default": "Delivery address" },
    { "type": "text",     "id": "subheading",    "label": "Subheading",      "default": "Select where you'd like your order delivered" },
    { "type": "color",    "id": "card_color",    "label": "Card Color",      "default": "#ffffff" },
    { "type": "color",    "id": "border_color",  "label": "Border Color",    "default": "#e8dcc8" },
    { "type": "color",    "id": "accent_color",  "label": "Gold Accent",     "default": "#d4af37" },
    { "type": "color",    "id": "text_color",    "label": "Text Color",      "default": "#3d2314" },
    { "type": "checkbox", "id": "show_phone",    "label": "Show Phone",      "default": true },
    { "type": "checkbox", "id": "hide_mobile",   "label": "Hide on Mobile",  "default": false },
    { "type": "checkbox", "id": "hide_desktop",  "label": "Hide on Desktop", "default": false }
  ],
  "presets": [{ "name": "Delivery Address Selector" }]
}
{% endschema %}
