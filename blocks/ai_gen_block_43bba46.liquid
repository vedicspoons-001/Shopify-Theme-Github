{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-nav-fix-{{ ai_gen_id }} {
    display: none;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-mobile-nav-fix-{{ ai_gen_id }} {
      display: block;
      background-color: {{ block.settings.background_color }};
      padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
      overflow: visible;
      width: 100%;
    }

    .ai-mobile-nav-container-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      flex-wrap: nowrap;
      width: 100%;
    }

    .ai-mobile-nav-list-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      flex-wrap: nowrap;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .ai-mobile-nav-item-{{ ai_gen_id }} {
      flex-shrink: 0;
    }

    .ai-mobile-nav-link-{{ ai_gen_id }} {
      display: block;
      padding: 8px 12px;
      color: {{ block.settings.text_color }};
      text-decoration: none;
      font-size: {{ block.settings.font_size }}px;
      font-weight: {{ block.settings.font_weight }};
      white-space: nowrap;
      position: relative;
      transition: opacity 0.2s ease;
    }

    .ai-mobile-nav-link-{{ ai_gen_id }}:hover {
      opacity: 0.7;
    }

    .ai-mobile-nav-link-{{ ai_gen_id }}.ai-active-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      bottom: {{ block.settings.underline_offset }}px;
      left: 12px;
      right: 12px;
      height: {{ block.settings.underline_thickness }}px;
      background-color: {{ block.settings.active_underline_color }};
    }

    .ai-mobile-nav-more-button-{{ ai_gen_id }} {
      flex-shrink: 0;
      background-color: {{ block.settings.more_button_background }};
      color: {{ block.settings.more_button_text }};
      border: 1px solid {{ block.settings.more_button_border }};
      border-radius: {{ block.settings.more_button_radius }}px;
      padding: 8px 16px;
      font-size: {{ block.settings.font_size }}px;
      font-weight: {{ block.settings.font_weight }};
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s ease;
    }

    .ai-mobile-nav-more-button-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.more_button_hover_background }};
      color: {{ block.settings.more_button_hover_text }};
    }

    .ai-mobile-nav-drawer-{{ ai_gen_id }} {
      position: fixed;
      top: 0;
      left: -100%;
      width: 80%;
      max-width: 300px;
      height: 100vh;
      background-color: {{ block.settings.drawer_background }};
      z-index: 9999;
      transition: left 0.3s ease;
      overflow-y: auto;
      box-shadow: 2px 0 10px rgba(0,0,0,0.1);
    }

    .ai-mobile-nav-drawer-{{ ai_gen_id }}.ai-open-{{ ai_gen_id }} {
      left: 0;
    }

    .ai-mobile-nav-drawer-header-{{ ai_gen_id }} {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px;
      border-bottom: 1px solid {{ block.settings.drawer_border_color }};
    }

    .ai-mobile-nav-drawer-title-{{ ai_gen_id }} {
      font-size: 18px;
      font-weight: 600;
      color: {{ block.settings.drawer_text_color }};
      margin: 0;
    }

    .ai-mobile-nav-close-button-{{ ai_gen_id }} {
      background: none;
      border: none;
      font-size: 24px;
      cursor: pointer;
      color: {{ block.settings.drawer_text_color }};
      padding: 4px 8px;
      line-height: 1;
    }

    .ai-mobile-nav-drawer-list-{{ ai_gen_id }} {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .ai-mobile-nav-drawer-item-{{ ai_gen_id }} {
      border-bottom: 1px solid {{ block.settings.drawer_border_color }};
    }

    .ai-mobile-nav-drawer-link-{{ ai_gen_id }} {
      display: block;
      padding: 16px;
      color: {{ block.settings.drawer_text_color }};
      text-decoration: none;
      font-size: {{ block.settings.font_size }}px;
      transition: background-color 0.2s ease;
      position: relative;
    }

    .ai-mobile-nav-drawer-link-{{ ai_gen_id }}.ai-active-{{ ai_gen_id }} {
      background-color: {{ block.settings.drawer_active_background }};
      font-weight: 600;
    }

    .ai-mobile-nav-drawer-link-{{ ai_gen_id }}.ai-active-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background-color: {{ block.settings.active_underline_color }};
    }

    .ai-mobile-nav-drawer-link-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.drawer_hover_background }};
    }

    .ai-mobile-nav-overlay-{{ ai_gen_id }} {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background-color: rgba(0,0,0,0.5);
      z-index: 9998;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .ai-mobile-nav-overlay-{{ ai_gen_id }}.ai-open-{{ ai_gen_id }} {
      opacity: 1;
      visibility: visible;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-mobile-nav-fix-{{ ai_gen_id }} {
      display: none !important;
    }
  }
{% endstyle %}

<mobile-nav-{{ ai_gen_id }} class="ai-mobile-nav-fix-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-nav-container-{{ ai_gen_id }}">
    <ul class="ai-mobile-nav-list-{{ ai_gen_id }}">
      {% assign visible_count = 0 %}
      {% for link in linklists[block.settings.menu].links %}
        {% if visible_count < block.settings.visible_items_count %}
          <li class="ai-mobile-nav-item-{{ ai_gen_id }}">
            <a 
              href="{{ link.url }}" 
              class="ai-mobile-nav-link-{{ ai_gen_id }} {% if link.active or link.child_active %}ai-active-{{ ai_gen_id }}{% endif %}"
            >
              {{ link.title }}
            </a>
          </li>
          {% assign visible_count = visible_count | plus: 1 %}
        {% endif %}
      {% endfor %}
    </ul>

    {% if linklists[block.settings.menu].links.size > block.settings.visible_items_count %}
      <button class="ai-mobile-nav-more-button-{{ ai_gen_id }}" data-more-button aria-label="Open menu">
        {{ block.settings.more_button_label }}
      </button>
    {% endif %}
  </div>

  <div class="ai-mobile-nav-overlay-{{ ai_gen_id }}" data-overlay></div>

  <div class="ai-mobile-nav-drawer-{{ ai_gen_id }}" data-drawer>
    <div class="ai-mobile-nav-drawer-header-{{ ai_gen_id }}">
      <h2 class="ai-mobile-nav-drawer-title-{{ ai_gen_id }}">{{ block.settings.drawer_title }}</h2>
      <button class="ai-mobile-nav-close-button-{{ ai_gen_id }}" aria-label="Close menu" data-close>×</button>
    </div>
    <ul class="ai-mobile-nav-drawer-list-{{ ai_gen_id }}">
      {% for link in linklists[block.settings.menu].links %}
        <li class="ai-mobile-nav-drawer-item-{{ ai_gen_id }}">
          <a 
            href="{{ link.url }}" 
            class="ai-mobile-nav-drawer-link-{{ ai_gen_id }} {% if link.active or link.child_active %}ai-active-{{ ai_gen_id }}{% endif %}"
          >
            {{ link.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</mobile-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class MobileNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.moreButton = this.querySelector('[data-more-button]');
        this.drawer = this.querySelector('[data-drawer]');
        this.overlay = this.querySelector('[data-overlay]');
        this.closeButton = this.querySelector('[data-close]');
      }

      connectedCallback() {
        if (this.moreButton) {
          this.moreButton.addEventListener('click', this.openDrawer.bind(this));
        }
        this.closeButton.addEventListener('click', this.closeDrawer.bind(this));
        this.overlay.addEventListener('click', this.closeDrawer.bind(this));
        document.addEventListener('keydown', this.handleEscape.bind(this));
      }

      openDrawer() {
        this.drawer.classList.add('ai-open-{{ ai_gen_id }}');
        this.overlay.classList.add('ai-open-{{ ai_gen_id }}');
        document.body.style.overflow = 'hidden';
      }

      closeDrawer() {
        this.drawer.classList.remove('ai-open-{{ ai_gen_id }}');
        this.overlay.classList.remove('ai-open-{{ ai_gen_id }}');
        document.body.style.overflow = '';
      }

      handleEscape(event) {
        if (event.key === 'Escape' && this.drawer.classList.contains('ai-open-{{ ai_gen_id }}')) {
          this.closeDrawer();
        }
      }

      disconnectedCallback() {
        if (this.moreButton) {
          this.moreButton.removeEventListener('click', this.openDrawer.bind(this));
        }
        this.closeButton.removeEventListener('click', this.closeDrawer.bind(this));
        this.overlay.removeEventListener('click', this.closeDrawer.bind(this));
        document.removeEventListener('keydown', this.handleEscape.bind(this));
      }
    }

    customElements.define('mobile-nav-{{ ai_gen_id }}', MobileNav{{ ai_gen_id }});
  })();
</script>

