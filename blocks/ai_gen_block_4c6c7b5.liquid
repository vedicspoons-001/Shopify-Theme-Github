{% doc %}
  @prompt
    Create a fully customizable announcement bar block with a blinking/flashing text effect. The block should:
    
    - Have a customizable background color (default: brown) and text color (default: white)
    - Every 3 seconds, the colors invert — text becomes the background color and background becomes the text color (blinking effect using CSS keyframes or JavaScript)
    - Customizable settings in the theme editor:
      - Announcement text
      - Background color picker
      - Text color picker
      - Blink interval in seconds (default 3)
      - Font size selector
      - Text alignment (left, center, right)
      - Enable/disable blink toggle
      - Optional CTA link URL and link text
      - Padding top and bottom
    - Smooth CSS keyframe animation for the color swap
    - Premium and attractive look suitable for a luxury gifting brand
    - Standalone section compatible with Online Store 2.0 themes, it should edge to edge amd the text style and ecverythuing adjusting option must be tghere and it must look attratuive and premium , not just given directly , it should cover the whole page by sides , it must also show the section width and fully cover the page 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    transition: background-color 0.5s ease, color 0.5s ease;
    overflow: hidden;
  }

  {% if block.settings.enable_blink %}
    .ai-announcement-bar-{{ ai_gen_id }}.ai-blink-active-{{ ai_gen_id }} {
      background-color: {{ block.settings.text_color }};
      color: {{ block.settings.background_color }};
    }
  {% endif %}

  .ai-announcement-bar-inner-{{ ai_gen_id }} {
    max-width: {% if block.settings.section_width == 'full' %}100%{% elsif block.settings.section_width == 'wide' %}1400px{% elsif block.settings.section_width == 'medium' %}1200px{% else %}1000px{% endif %};
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-announcement-bar-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: {{ block.settings.content_gap }}px;
    flex-wrap: wrap;
  }

  .ai-announcement-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    margin: 0;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-announcement-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: {{ block.settings.cta_font_weight }};
    text-transform: {{ block.settings.cta_text_transform }};
    letter-spacing: {{ block.settings.cta_letter_spacing }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    white-space: nowrap;
  }

  .ai-announcement-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
    transform: translateY(-1px);
  }

  {% if block.settings.enable_blink %}
    .ai-announcement-bar-{{ ai_gen_id }}.ai-blink-active-{{ ai_gen_id }} .ai-announcement-cta-{{ ai_gen_id }} {
      background-color: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
      border-color: {{ block.settings.background_color }};
    }

    .ai-announcement-bar-{{ ai_gen_id }}.ai-blink-active-{{ ai_gen_id }} .ai-announcement-cta-{{ ai_gen_id }}:hover {
      opacity: 0.9;
    }
  {% endif %}

  {% if block.settings.show_decorative_line %}
    .ai-announcement-bar-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: {{ block.settings.decorative_line_height }}px;
      background: {{ block.settings.decorative_line_color }};
    }
  {% endif %}

  {% if block.settings.show_bottom_line %}
    .ai-announcement-bar-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: {{ block.settings.bottom_line_height }}px;
      background: {{ block.settings.bottom_line_color }};
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-inner-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-announcement-bar-content-{{ ai_gen_id }} {
      justify-content: center;
      text-align: center;
      gap: {{ block.settings.content_gap | times: 0.7 }}px;
    }

    .ai-announcement-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }

    .ai-announcement-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_cta_font_size }}px;
      padding: {{ block.settings.cta_padding_vertical | times: 0.8 }}px {{ block.settings.cta_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }}
  class="ai-announcement-bar-{{ ai_gen_id }}"
  data-blink-enabled="{{ block.settings.enable_blink }}"
  data-blink-interval="{{ block.settings.blink_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-announcement-bar-inner-{{ ai_gen_id }}">
    <div class="ai-announcement-bar-content-{{ ai_gen_id }}">
      {% if block.settings.announcement_text != blank %}
        <p class="ai-announcement-text-{{ ai_gen_id }}">
          {{ block.settings.announcement_text }}
        </p>
      {% endif %}

      {% if block.settings.cta_link != blank and block.settings.cta_text != blank %}
        <a
          href="{{ block.settings.cta_link }}"
          class="ai-announcement-cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.blinkInterval = null;
      }

      connectedCallback() {
        const blinkEnabled = this.dataset.blinkEnabled === 'true';
        const blinkIntervalSeconds = parseFloat(this.dataset.blinkInterval) || 3;

        if (blinkEnabled) {
          this.startBlinking(blinkIntervalSeconds);
        }
      }

      startBlinking(intervalSeconds) {
        const intervalMs = intervalSeconds * 1000;

        this.blinkInterval = setInterval(() => {
          this.classList.add('ai-blink-active-{{ ai_gen_id }}');

          setTimeout(() => {
            this.classList.remove('ai-blink-active-{{ ai_gen_id }}');
          }, intervalMs / 2);
        }, intervalMs);
      }

      disconnectedCallback() {
        if (this.blinkInterval) {
          clearInterval(this.blinkInterval);
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>

