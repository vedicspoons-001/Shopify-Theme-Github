{% doc %}
  @prompt
    Create an elegant Curated Related Products section with manual product selection via metafield. 
    
    Features needed:
    - Uses product metafield (custom.curated_products) to display manually selected products
    - Premium card design with three style options: shadow (elegant with depth), bordered (clean lines), minimal (simple)
    - Warm brown (#8B4513) and gold (#D4AF37) accent colors for premium Indian sweets brand
    - Smooth hover animations: image scale effect and title color transition
    - Responsive grid layout with separate mobile/desktop column controls
    - Light cream (#F9F7F4) transparent image backgrounds
    - Customizable heading with left/center alignment
    - Show/hide price toggle
    - Adjustable spacing and padding controls
    - Sale price display with strikethrough regular price
    - Mobile-optimized typography and spacing
    
    The section should only display when products are selected in the metafield, with elegant spacing, professional typography, and smooth transitions that create a premium shopping experience.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% assign curated_products = product.metafields.custom.curated_products.value %}

{% if curated_products != blank and curated_products.size > 0 %}
  {% style %}
    .ai-curated-products-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    }

    .ai-curated-products__container-{{ ai_gen_id }} {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .ai-curated-products__header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.heading_spacing }}px;
      text-align: {{ block.settings.heading_alignment }};
    }

    .ai-curated-products__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
      color: {{ block.settings.heading_color }};
      margin: 0;
      font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
      font-weight: {{ block.settings.heading_font.weight }};
    }

    .ai-curated-products__grid-{{ ai_gen_id }} {
      display: grid;
      {% if block.settings.columns_mobile == 1 %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    @media screen and (min-width: 750px) {
      .ai-curated-products__grid-{{ ai_gen_id }} {
        grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
        gap: {{ block.settings.grid_gap_desktop }}px;
      }

      .ai-curated-products__heading-{{ ai_gen_id }} {
        font-size: {{ block.settings.heading_size | times: 1.2 }}px;
      }
    }

    .ai-curated-products__card-{{ ai_gen_id }} {
      position: relative;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s ease;
      {% if block.settings.card_style == 'shadow' %}
        background: {{ block.settings.card_background }};
        border-radius: {{ block.settings.card_border_radius }}px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        padding: {{ block.settings.card_padding }}px;
      {% elsif block.settings.card_style == 'bordered' %}
        background: {{ block.settings.card_background }};
        border: 1px solid {{ block.settings.card_border_color }};
        border-radius: {{ block.settings.card_border_radius }}px;
        padding: {{ block.settings.card_padding }}px;
      {% else %}
        background: transparent;
      {% endif %}
    }

    .ai-curated-products__card-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
    }

    {% if block.settings.card_style == 'shadow' %}
      .ai-curated-products__card-{{ ai_gen_id }}:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      }
    {% endif %}

    .ai-curated-products__image-wrapper-{{ ai_gen_id }} {
      position: relative;
      width: 100%;
      padding-bottom: 100%;
      overflow: hidden;
      border-radius: {{ block.settings.image_border_radius }}px;
      background-color: {{ block.settings.image_background }};
      margin-bottom: {{ block.settings.content_spacing }}px;
    }

    .ai-curated-products__image-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .ai-curated-products__card-{{ ai_gen_id }}:hover .ai-curated-products__image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }

    .ai-curated-products__content-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .ai-curated-products__title-{{ ai_gen_id }} {
      font-size: 14px;
      line-height: 1.4;
      color: {{ block.settings.title_color }};
      margin: 0;
      transition: color 0.3s ease;
    }

    @media screen and (min-width: 750px) {
      .ai-curated-products__title-{{ ai_gen_id }} {
        font-size: 16px;
      }
    }

    .ai-curated-products__card-{{ ai_gen_id }}:hover .ai-curated-products__title-{{ ai_gen_id }} {
      color: {{ block.settings.title_hover_color }};
    }

    .ai-curated-products__price-wrapper-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .ai-curated-products__price-{{ ai_gen_id }} {
      font-size: 14px;
      font-weight: 600;
      color: {{ block.settings.price_color }};
      margin: 0;
    }

    @media screen and (min-width: 750px) {
      .ai-curated-products__price-{{ ai_gen_id }} {
        font-size: 16px;
      }
    }

    .ai-curated-products__compare-price-{{ ai_gen_id }} {
      font-size: 13px;
      color: {{ block.settings.compare_price_color }};
      text-decoration: line-through;
      opacity: 0.7;
    }

    @media screen and (min-width: 750px) {
      .ai-curated-products__compare-price-{{ ai_gen_id }} {
        font-size: 14px;
      }
    }

    .ai-curated-products__sale-badge-{{ ai_gen_id }} {
      display: inline-block;
      padding: 4px 8px;
      background-color: {{ block.settings.sale_badge_background }};
      color: {{ block.settings.sale_badge_text }};
      font-size: 11px;
      font-weight: 600;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    @media screen and (min-width: 750px) {
      .ai-curated-products__sale-badge-{{ ai_gen_id }} {
        font-size: 12px;
      }
    }
  {% endstyle %}

  <curated-products-{{ ai_gen_id }} class="ai-curated-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-curated-products__container-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <div class="ai-curated-products__header-{{ ai_gen_id }}">
          <h2 class="ai-curated-products__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        </div>
      {% endif %}

      <div class="ai-curated-products__grid-{{ ai_gen_id }}">
        {% for curated_product in curated_products limit: block.settings.products_to_show %}
          <a href="{{ curated_product.url }}" class="ai-curated-products__card-{{ ai_gen_id }}">
            <div class="ai-curated-products__image-wrapper-{{ ai_gen_id }}">
              {% if curated_product.featured_image %}
                <img
                  src="{{ curated_product.featured_image | image_url: width: 600 }}"
                  alt="{{ curated_product.featured_image.alt | escape }}"
                  class="ai-curated-products__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-curated-products__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-curated-products__content-{{ ai_gen_id }}">
              <h3 class="ai-curated-products__title-{{ ai_gen_id }}">{{ curated_product.title }}</h3>

              {% if block.settings.show_price %}
                <div class="ai-curated-products__price-wrapper-{{ ai_gen_id }}">
                  {% if curated_product.compare_at_price > curated_product.price %}
                    <span class="ai-curated-products__compare-price-{{ ai_gen_id }}">
                      {{ curated_product.compare_at_price | money }}
                    </span>
                    <span class="ai-curated-products__price-{{ ai_gen_id }}">
                      {{ curated_product.price | money }}
                    </span>
                    <span class="ai-curated-products__sale-badge-{{ ai_gen_id }}">Sale</span>
                  {% else %}
                    <span class="ai-curated-products__price-{{ ai_gen_id }}">
                      {{ curated_product.price | money }}
                    </span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </curated-products-{{ ai_gen_id }}>

  <script>
    (function() {
      class CuratedProducts{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.cards = this.querySelectorAll('.ai-curated-products__card-{{ ai_gen_id }}');
          this.setupAccessibility();
        }

        setupAccessibility() {
          this.cards.forEach((card) => {
            card.setAttribute('role', 'link');
          });
        }
      }

      customElements.define('curated-products-{{ ai_gen_id }}', CuratedProducts{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Curated related products",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "This block displays products from the product.metafields.custom.curated_products metafield. Add a product_list metafield to your products to use this feature."
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "faculty_glyphic_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#5e1111"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Bottom spacing",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "label": "Grid gap on desktop",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "label": "Grid gap on mobile",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Style",
      "options": [
        {
          "value": "shadow",
          "label": "Shadow"
        },
        {
          "value": "bordered",
          "label": "Bordered"
        },
        {
          "value": "minimal",
          "label": "Minimal"
        }
      ],
      "default": "shadow"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#D4AF37"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Background",
      "default": "#F9F7F4"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Spacing below image",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Product title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#5e1111"
    },
    {
      "type": "color",
      "id": "title_hover_color",
      "label": "Hover color",
      "default": "#8B4513"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
