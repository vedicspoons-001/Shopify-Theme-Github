    {
      "type": "color",
      "id": "price_color",
      "label": "Color",
      "default": "#5e1111"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare at price color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "sale_badge_background",
      "label": "Sale badge background",
      "default": "#8B4513"
    },
    {
      "type": "color",
      "id": "sale_badge_text",
      "label": "Sale badge text",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
