{%- assign visible_variants = product.variants | where_exp: "variant", "variant.metafields.custom.hidden != true" -%}

{% liquid
  if section.settings.desktop_media_position == 'left'
    assign render_order = 'media,product-details'
  else
    assign render_order = 'product-details,media'
  endif

  assign product_has_media = true
  if closest.product.media.size == 0
    assign product_has_media = false
  endif

  assign product_grid_class = 'product-information__grid'

  if product_has_media == false
    assign product_grid_class = product_grid_class | append: ' product-information--media-none'
  elsif section.settings.desktop_media_position == 'right'
    assign product_grid_class = product_grid_class | append: ' product-information--media-right'
  else
    assign product_grid_class = product_grid_class | append: ' product-information--media-left'
  endif

  if section.settings.equal_columns
    assign product_grid_class = product_grid_class | append: ' product-information__grid--half'

    if section.settings.limit_details_width
      assign product_grid_class = product_grid_class | append: ' product-information__grid--limit-details'
    endif
  endif

  case section.settings.content_width
    when 'content-center-aligned'
      assign content_width = 'page-width'
    when 'content-full-width'
      assign content_width = 'full-width'
  endcase
%}

<script type="application/ld+json">
  {{ closest.product | structured_data }}
</script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="product-information section section--{{ content_width }} spacing-style color-{{ section.settings.color_scheme }} relative"
  style="{% render 'spacing-style', settings: section.settings %} --gap: {{ section.settings.gap }}px;"
>
  {% if section.settings.desktop_media_position == 'left' and product_has_media %}
    {% assign product_href = '#ProductInformation-' | append: section.id %}
    {% render 'skip-to-content-link', href: product_href, text: 'accessibility.skip_to_product_info' %}
  {% endif %}
  <div
    class="{{ product_grid_class }}"
    data-product-grid-content
  >
    {% assign render_order_array = render_order | split: ',' %}
    {% capture media %}
      <div
        class="product-information__media"
        data-testid="product-information-media"
      >
        {%- content_for 'block',
          type: '_product-media-gallery',
          id: 'media-gallery',
          closest.product: closest.product
        -%}
      </div>
    {% endcapture %}

    {% capture details %}
      {% content_for 'block',
        type: '_product-details',
        id: 'product-details',
        closest.product: closest.product
      %}
    {% endcapture %}

    {% for block in render_order_array %}
      {% if block == 'media' and product_has_media %}
        {{ media }}
      {% elsif block == 'product-details' %}
        {{ details }}
      {% endif %}
    {% endfor %}
  </div>

  {% content_for 'blocks' %}
</div>

{%- comment -%}
  Variant → gallery mapping (metafield: variant.metafields.custom.variant_gallery)
  This is used by JS below to show only the images for the selected variant.
  IMPORTANT: We map metafield files to product.media by matching image URLs,
  then store the product media IDs in JSON.
{%- endcomment -%}
{% if product.variants.size > 0 %}
  <script id="variant-gallery-data-{{ section.id }}" type="application/json">
    {
    {%- assign first_variant_done = false -%}
    {%- for variant in product.variants -%}
      {%- if variant.metafields.custom.variant_gallery != blank -%}
        {%- assign media_ids = '' -%}

        {%- for file in variant.metafields.custom.variant_gallery -%}
          {%- assign file_url = file | image_url: width: 600 -%}
          {%- assign matched_media_id = '' -%}

          {%- for media in product.media -%}
            {%- assign media_url = media | image_url: width: 600 -%}
            {%- if media_url == file_url -%}
              {%- assign matched_media_id = media.id -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if matched_media_id != '' -%}
            {%- if media_ids != '' -%}
              {%- assign media_ids = media_ids | append: ',' -%}
            {%- endif -%}
            {%- assign media_ids = media_ids | append: '"' | append: matched_media_id | append: '"' -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if media_ids != '' -%}
          {%- if first_variant_done -%},{%- endif -%}
          "{{ variant.id }}": [{{ media_ids }}]
          {%- assign first_variant_done = true -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    }
  </script>
{% endif %}

{% stylesheet %}
  .product-information {
    gap: var(--gap) 0;
  }

  /* Base grid layout */
  .product-information__grid {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
  }

  /* Default column positions */
  .product-details {
    order: 1;
  }

  .product-information__media {
    order: 0;
    width: 0;
    min-width: 100%;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .product-information__media {
      grid-column: 1 / -1;
    }

    .product-details {
      grid-column: 2 / 3;
    }
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    .product-information__grid {
      grid-column: 2;
    }

    /* Position when there is no media */
    .product-information__grid.product-information--media-none,
    .product-information__grid:has(.product-information__media:empty) {
      .product-details {
        width: var(--narrow-content-width);
        margin: 0 auto;
      }
    }

    /* Position when there is media */
    .product-information__grid:not(:has(.product-information__media:empty)) {
      /* Media on the left side */
      &.product-information--media-left {
        grid-template-columns: 1fr min(50vw, var(--sidebar-width));

        .product-information__media {
          padding-right: calc(var(--gap, 0) / 2);
        }

        .product-details {
          padding-left: calc(var(--gap, 0) / 2);
        }

        &:has(.media-gallery--extend) {
          grid-column: 1 / 3;
        }
      }

      /* Media on the right side */
      &.product-information--media-right {
        grid-template-columns: min(50vw, var(--sidebar-width)) 1fr;

        .product-information__media {
          padding-left: calc(var(--gap, 0) / 2);
          order: 1;
        }

        .product-details {
          padding-right: calc(var(--gap, 0) / 2);
          order: 0;
        }

        &:has(.media-gallery--extend) {
          grid-column: 2 / -1;
        }
      }

      /* Equal width columns */
      &.product-information__grid--half,
      &.product-information__grid--half:has(.media-gallery--extend) {
        grid-column: 1 / -1;
        grid-template-columns:
          var(--full-page-grid-margin) calc(var(--full-page-grid-central-column-width) / 2) calc(
            var(--full-page-grid-central-column-width) / 2
          )
          var(--full-page-grid-margin);

        &.product-information--media-left {
          .product-information__media {
            grid-column: 2 / 3;

            &:has(.media-gallery--extend) {
              grid-column: 1 / 3;
            }
          }

          .product-details {
            grid-column: 3 / 4;
          }
        }

        &.product-information--media-right {
          .product-information__media {
            grid-column: 3 / 4;

            &:has(.media-gallery--extend) {
              grid-column: 3 / -1;
            }
          }

          .product-details {
            grid-column: 2 / 3;
          }
        }
      }
    }

    /* Handle full width section */
    .section--full-width {
      .product-information__grid:not(:has(.product-information__media:empty)),
      .product-information__grid:not(:has(.product-information__media:empty)) {
        &.product-information--media-left,
        &.product-information--media-right {
          grid-column: 1 / -1;
        }

        &.product-information--media-left .product-details {
          padding-inline-end: var(--padding-lg);
        }

        &.product-information--media-right .product-details {
          padding-inline-start: var(--padding-lg);
        }

        &.product-information__grid--half.product-information--media-left {
          .product-information__media {
            grid-column: 1 / 3;
          }

          .product-details {
            grid-column: 3 / -1;
          }
        }

        &.product-information__grid--half.product-information--media-right {
          .product-information__media {
            grid-column: 3 / -1;
          }

          .product-details {
            grid-column: 1 / 3;
          }
        }
      }
    }
  }

  /* Wider sidebar for large screens */
  @media screen and (min-width: 1200px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      grid-template-columns: 2fr 1fr;
    }

    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-right {
      grid-template-columns: 1fr 2fr;
    }
  }

  .product-information__grid--limit-details .product-details > .group-block {
    max-width: var(--sidebar-width);
  }

  /* If the header is sticky, make product details content stick underneath the header */
  body:has(#header-group #header-component[data-sticky-state='active']) .product-details.sticky-content--desktop {
    --sticky-header-offset: var(--header-height);
  }
{% endstylesheet %}

{%- comment -%} CUSTOM CODE: Hide Unavailable Variants {%- endcomment -%}
<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('Script loaded');
  
  const hiddenVariantIds = {{ product.variants | where_exp: "variant", "variant.metafields.custom.hidden == true" | map: "id" | json }};
  console.log('Hidden variant IDs:', hiddenVariantIds);
  
  // Convert GIDs to just the numeric IDs
  const hiddenIds = hiddenVariantIds.map(id => {
    const match = id.toString().match(/\d+$/);
    return match ? parseInt(match[0]) : null;
  }).filter(id => id !== null);
  
  console.log('Parsed hidden IDs:', hiddenIds);
  
  // Find all variant option inputs
  const variantInputs = document.querySelectorAll('input[data-variant-id]');
  console.log('Found variant inputs:', variantInputs.length);
  
  variantInputs.forEach(function(input) {
    const variantId = parseInt(input.getAttribute('data-variant-id'));
    console.log('Checking variant ID:', variantId, 'Hidden?', hiddenIds.includes(variantId));
    
    if (hiddenIds.includes(variantId)) {
      const container = input.closest('label') || input.parentElement;
      if (container) {
        container.style.display = 'none';
        console.log('Hiding variant:', variantId);
      }
      input.disabled = true;
    }
  });
});


  let isUpdating = false;
  
  function hideUnavailableVariants() {
    if (isUpdating) return;
    isUpdating = true;
    
    // Find all select dropdowns
    const selects = document.querySelectorAll('select[name^="options"]');
    
    if (selects.length === 0) {
      isUpdating = false;
      return;
    }
    
    selects.forEach((select, optionIndex) => {
      const options = select.querySelectorAll('option');
      
      options.forEach(option => {
        // Skip empty/placeholder options
        if (!option.value || option.value === '') {
          option.style.display = 'block';
          option.disabled = false;
          return;
        }
        
        // SIMPLE RULE: If option text contains "- Unavailable", hide it
        // Otherwise, show it
        if (option.textContent.includes('- Unavailable')) {
          option.style.display = 'none';
          option.disabled = true;
        } else {
          option.style.display = 'block';
          option.disabled = false;
        }
      });
    });
    
    isUpdating = false;
  }
  
  // Run on page load
  setTimeout(hideUnavailableVariants, 200);
  
  // Watch for changes
  const productForm = document.querySelector('.product-form, form[action*="/cart/add"]');
  
  if (productForm) {
    const observer = new MutationObserver(function(mutations) {
      setTimeout(hideUnavailableVariants, 50);
    });
    
    observer.observe(productForm, {
      childList: true,
      subtree: true
    });
  }
  
  // Listen for select changes
  document.addEventListener('change', function(e) {
    if (e.target.matches('select[name^="options"]')) {
      setTimeout(hideUnavailableVariants, 50);
    }
  });
  
  // Re-run periodically
  setInterval(hideUnavailableVariants, 500);
  
});

// Hide variants marked as hidden in metafields
setTimeout(function() {
  const hiddenVariantIds = {{ product.variants | where_exp: "variant", "variant.metafields.custom.hidden == true" | map: "id" | json }};
  const hiddenIds = hiddenVariantIds.map(id => {
    const match = id.toString().match(/\d+$/);
    return match ? parseInt(match[0]) : null;
  }).filter(id => id !== null);
  
  const variantInputs = document.querySelectorAll('input[data-variant-id]');
  variantInputs.forEach(function(input) {
    const variantId = parseInt(input.getAttribute('data-variant-id'));
    if (hiddenIds.includes(variantId)) {
      const container = input.closest('label') || input.parentElement;
      if (container) {
        container.style.display = 'none';
      }
      input.disabled = true;
    }
  });
}, 600); // Run after hideUnavailableVariants finishes
</script>

<script>
(function() {
  function autoSelectVariants() {
    // Get all variant picker fieldsets
    const variantPickers = document.querySelectorAll('variant-radios, variant-selects');
    
    if (variantPickers.length === 0) {
      // Fallback: try to find inputs directly
      const allOptions = document.querySelectorAll('input[type="radio"][name^="options"]');
      
      // Group by option name
      const optionGroups = {};
      allOptions.forEach(input => {
        if (!optionGroups[input.name]) {
          optionGroups[input.name] = [];
        }
        optionGroups[input.name].push(input);
      });
      
      // Select first available in each group
      Object.values(optionGroups).forEach(group => {
        const firstAvailable = group.find(input => !input.disabled);
        if (firstAvailable && !firstAvailable.checked) {
          firstAvailable.checked = true;
          firstAvailable.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    } else {
      // Use variant pickers
      variantPickers.forEach(picker => {
        const firstInput = picker.querySelector('input:not(:disabled)');
        if (firstInput && !firstInput.checked) {
          firstInput.checked = true;
          firstInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    }
  }
  
  // Try multiple times to ensure it works
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoSelectVariants);
  } else {
    autoSelectVariants();
  }
  
  setTimeout(autoSelectVariants, 100);
  setTimeout(autoSelectVariants, 500);
})();
</script>

{%- comment -%}
  CUSTOM CODE: Variant gallery control
  Shows only the media whose data-media-id is listed in the selected variant's
  metafield: variant.metafields.custom.variant_gallery
{%- endcomment -%}
<script>
document.addEventListener('DOMContentLoaded', function() {
  var dataEl = document.querySelector('#variant-gallery-data-{{ section.id }}');
  if (!dataEl) return;

  var mapping = {};
  try {
    mapping = JSON.parse(dataEl.textContent.trim());
  } catch (e) {
    console.error('Variant gallery JSON error', e);
    return;
  }

  // All media elements inside the product gallery that have data-media-id
  var mediaEls = document.querySelectorAll('.product-information__media [data-media-id]');
  if (!mediaEls.length) return;

  // The hidden variant ID input in the add-to-cart form
  var variantIdInput = document.querySelector('form[action*="/cart/add"] [name="id"]');
  if (!variantIdInput) return;

  function updateGallery(variantId) {
    var allowed = mapping[variantId];

    // No mapping for this variant → show all media
    if (!allowed || !allowed.length) {
      mediaEls.forEach(function (el) {
        el.style.display = '';
      });
      return;
    }

    mediaEls.forEach(function (el) {
      var mid = el.getAttribute('data-media-id');
      // compare as string and as number, just in case
      if (allowed.indexOf(mid) !== -1 || allowed.indexOf(parseInt(mid)) !== -1) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  }

  // Initial state
  if (variantIdInput.value) {
    updateGallery(variantIdInput.value);
  }

  // When the variant ID input changes
  variantIdInput.addEventListener('change', function (e) {
    updateGallery(e.target.value);
  });

  // Some themes dispatch a custom event on variant change; support that too
  document.addEventListener('variant:changed', function (e) {
    if (e.detail && e.detail.variant && e.detail.variant.id) {
      updateGallery(String(e.detail.variant.id));
    }
  });
});
</script>




