{%- comment -%} CUSTOM CODE: Login Gate for Add to Cart {%- endcomment -%}
<script>
(function() {

  var isLoggedIn = {{ customer | json }} !== null;

  // ── After login: auto-add saved item + redirect back ──────────────────────
  if (isLoggedIn) {
    var savedVariantId = sessionStorage.getItem('atc_variant_id');
    var savedQty       = sessionStorage.getItem('atc_quantity');
    var savedReturnUrl = sessionStorage.getItem('atc_return_url');

    if (savedVariantId && savedReturnUrl) {
      // Clear storage immediately so it doesn't re-trigger
      sessionStorage.removeItem('atc_variant_id');
      sessionStorage.removeItem('atc_quantity');
      sessionStorage.removeItem('atc_return_url');

      // Add to cart via AJAX
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: parseInt(savedVariantId),
          quantity: parseInt(savedQty) || 1
        })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        // Show redirect notification then go back to product page
        showRedirectNotice(savedReturnUrl);
      })
      .catch(function(err) {
        console.error('Auto add-to-cart failed:', err);
        window.location.href = savedReturnUrl;
      });
    }
  }

  // ── Show "Redirecting..." toast notification ──────────────────────────────
  function showRedirectNotice(returnUrl) {
    var banner = document.createElement('div');
    banner.innerHTML = '✅ Logged in! Redirecting you back in <strong><span id="atc-countdown">3</span>s</strong>...';
    banner.style.cssText = [
      'position:fixed',
      'bottom:24px',
      'left:50%',
      'transform:translateX(-50%)',
      'background:#1a1a1a',
      'color:#fff',
      'padding:14px 24px',
      'border-radius:8px',
      'font-size:15px',
      'z-index:99999',
      'box-shadow:0 4px 20px rgba(0,0,0,0.3)',
      'text-align:center',
      'min-width:280px'
    ].join(';');
    document.body.appendChild(banner);

    var count = 3;
    var interval = setInterval(function() {
      count--;
      var el = document.getElementById('atc-countdown');
      if (el) el.textContent = count;
      if (count <= 0) {
        clearInterval(interval);
        window.location.href = returnUrl;
      }
    }, 1000);
  }

  // ── Intercept Add to Cart for guests ─────────────────────────────────────
  if (!isLoggedIn) {
    document.addEventListener('submit', function(e) {
      var form = e.target;
      if (!form || !form.action || form.action.indexOf('/cart/add') === -1) return;

      e.preventDefault();
      e.stopImmediatePropagation();

      var variantInput = form.querySelector('[name="id"]');
      var qtyInput     = form.querySelector('[name="quantity"]');
      var variantId    = variantInput ? variantInput.value : null;
      var quantity     = qtyInput ? qtyInput.value : 1;

      if (!variantId) return;

      // Save product + current page to sessionStorage
      sessionStorage.setItem('atc_variant_id', variantId);
      sessionStorage.setItem('atc_quantity', quantity);
      sessionStorage.setItem('atc_return_url', window.location.href);

      // Redirect to login — return_to brings them back to THIS page after login
      window.location.href = '/account/login?return_to=' + encodeURIComponent(window.location.pathname + window.location.search);

    }, true);

    // ── If customer comes BACK without logging in (e.g. hits back button) ──
    // sessionStorage still has the data, so we detect they're on the same
    // product page and just leave it — product is NOT in cart (correct).
    // But if they navigate away entirely, clear the saved data.
    window.addEventListener('pageshow', function() {
      var savedReturnUrl = sessionStorage.getItem('atc_return_url');
      if (savedReturnUrl && window.location.href !== savedReturnUrl) {
        // They navigated somewhere else without logging in — clear saved data
        // but redirect them back to the product page they were on
        sessionStorage.removeItem('atc_variant_id');
        sessionStorage.removeItem('atc_quantity');
        sessionStorage.removeItem('atc_return_url');
        window.location.href = savedReturnUrl;
      }
    });
  }

})();
</script>




